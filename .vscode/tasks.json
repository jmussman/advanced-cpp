{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "1. CMake: Generation Phase",
            "type": "shell",
            // Modern alternative: "cmake -S . -B build -G Ninja"
            "command": "cmake -Bbuild -H. -GNinja",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            }
        },
        {
            "label": "2. Ninja: Compilation Phase",
            "type": "shell",
            "command": "ninja",
            "options": {
                "cwd": "${workspaceFolder}/build"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": false
            }
        },
        {
            "label": "CMake: Full Pipeline (Generate + Build)",
            "dependsOrder": "sequence",
            "dependsOn": [
                "1. CMake: Generation Phase",
                "2. Ninja: Compilation Phase"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ]
}